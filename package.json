{
  "name": "nexcart",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "supabase:check": "node scripts/check-supabase-workflow.mjs",
    "supabase:status": "node scripts/supabase-workflow.mjs status",
    "supabase:new": "node scripts/supabase-workflow.mjs new",
    "supabase:link": "node scripts/supabase-workflow.mjs link",
    "supabase:push": "node scripts/supabase-workflow.mjs push",
    "supabase:pull": "node scripts/supabase-workflow.mjs pull"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@supabase/supabase-js": "^2.47.0",
    "@supabase/ssr": "^0.5.2",
    "zustand": "^5.0.0",
    "framer-motion": "^12.0.0",
    "next-sanity": "^9.8.0",
    "@sanity/client": "^6.24.0",
    "@sanity/image-url": "^1.1.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "lucide-react": "^0.468.0",
    "recharts": "^2.15.0",
    "gsap": "^3.12.0",
    "stripe": "^22.0.0",
    "@stripe/stripe-js": "^9.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.5.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.3.0",
    "vitest": "^2.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.{css,json,md}": ["prettier --write"]
  }
}
